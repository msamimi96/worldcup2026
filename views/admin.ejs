<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Cup 2026</title>

    <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="admin-container">
    <h2>Admin Panel</h2>

    <form action="/admin/update-match" method="POST">

        <!-- MATCH SELECT -->
        <label>Choose Match</label>
        <select name="match_id" required>

            <% matches.forEach(match => { %>
                <option value="<%= match.id %>">
                    <%= match.team1 %> vs <%= match.team2 %>
                    ( <%= new Date(match.kickoff).toLocaleString() %> )
                </option>
            <% }) %>

        </select>

        <hr>

        <!-- RESULT INPUT -->
        <h3>Match Result</h3>

        <input type="number" name="result1" placeholder="Team 1 Goals" required>
        <input type="number" name="result2" placeholder="Team 2 Goals" required>

        <hr>

        <!-- POINTS TABLE -->
        <h3>Assign Points</h3>

        <table border="1" cellpadding="8">

            <tr>
                <th>User</th>
                <th>Points</th>
            </tr>

            <% users.forEach(user => { %>

            <tr>

                <td>
                    <%= user.username %>
                    <input type="hidden" name="user_id[]" value="<%= user.id %>">
                </td>

                <td>
                    <input type="number" name="points[]" step="0.1" class="points-input"/>
                </td>

            </tr>

            <% }) %>

        </table>

        <br>

        <button type="submit">
            به روز رسانی جدول
        </button>

    </form>
    <hr>

<!-- =========================
     USER MANAGEMENT
========================= -->

    <h3>
        User Management
    </h3>

    <!-- CREATE USER -->

    <form action="/admin/users/create" method="POST">

        <input
            type="text"
            name="username"
            placeholder="New Username"
            required
        >
        <input 
            type="text"
            name="display_name"
            placeholder="Farsi Name"
            required
        >

        <button type="submit">
            Create User
        </button>

    </form>

    <br>

    <!-- USERS LIST -->

    <table border="1" cellpadding="8">

        <tr>

            <th>
                Username
            </th>

            <th>
                Reset Password
            </th>

            <th>
                Delete User
            </th>

        </tr>

        <% users.forEach(user => { %>

        <tr>

            <td>
                <%= user.username %>
            </td>

            <!-- RESET PASSWORD -->

            <td>

                <form
                    action="/admin/users/reset-password"
                    method="POST"
                >

                    <input
                        type="hidden"
                        name="user_id"
                        value="<%= user.id %>"
                    >

                    <button type="submit">
                        Reset Password
                    </button>

                </form>

            </td>

            <!-- DELETE USER -->

            <td>

                <form
                    action="/admin/users/delete"
                    method="POST"
                >

                    <input
                        type="hidden"
                        name="user_id"
                        value="<%= user.id %>"
                    >

                    <button type="submit">
                        Delete
                    </button>

                </form>

            </td>

        </tr>

        <% }) %>

    </table>

    <hr>

        <!-- =========================
            MATCH MANAGEMENT
        ========================= -->

        <h3>
            Match Management
        </h3>

        <!-- CREATE MATCH -->

        <form action="/admin/matches/create" method="POST">

            <input
                type="text"
                name="team1"
                placeholder="Team 1"
                required
            >

            <input
                type="text"
                name="team2"
                placeholder="Team 2"
                required
            >

            <input
                type="datetime-local"
                name="kickoff"
                required
            >

            <button type="submit">
                Add Match
            </button>

        </form>

        <br>

        <!-- MATCHES TABLE -->

        <table border="1" cellpadding="8">

            <tr>

                <th>
                    Match
                </th>

                <th>
                    Kickoff
                </th>

                <th>
                    Delete
                </th>

            </tr>

            <% matches.forEach(match => { %>

            <tr>

                <td>
                    <%= match.team1 %>
                    VS
                    <%= match.team2 %>
                </td>

                <td>
                    <%= new Date(match.kickoff).toLocaleString() %>
                </td>

                <td>

                    <form
                        action="/admin/matches/delete"
                        method="POST"
                    >

                        <input
                            type="hidden"
                            name="match_id"
                            value="<%= match.id %>"
                        >

                        <button type="submit">
                            Delete
                        </button>

                    </form>

                </td>

            </tr>

            <% }) %>

        </table>

</div>


</body>

</html>