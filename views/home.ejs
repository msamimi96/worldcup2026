<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Cup 2026</title>

    <link rel="stylesheet" href="/css/homepage.css">
</head>

<body>

    <% const reversedMatches = matches.slice().reverse(); %>
<div class="page">

    <!-- TOP BAR -->
    <div class="top-bar">

        <div class="user-name">
            خوش اومدی، <%= user.display_name %>
        </div>

        <form action="/logout" method="POST">
            <button type="submit">خروج</button>
        </form>

    </div>

    <!-- MATCHES -->
    <div class="upcoming-matches-container">

        <h2 class="title">بازی ها</h2>

        <div class="upcoming-matches" id="matchesContainer">

            <% matches.slice().reverse().forEach(match => { %>

                <% const isLocked = new Date(match.kickoff) < new Date(); %>

                <form class="match <%= isLocked ? 'expired-match' : '' %>" 
                      data-kickoff="<%= new Date(match.kickoff).toISOString() %>"
                      action="/predict"
                      method="POST">

                    <input type="hidden" name="match_id" value="<%= match.id %>">

                    <!-- DATE -->
                    <div class="date-time">

                        <span>
                            <%= new Intl.DateTimeFormat('fa-IR-u-ca-persian', {
                                year: 'numeric',
                                month: '2-digit',
                                day: '2-digit',
                                timeZone: 'Asia/Tehran'
                            }).format(new Date(match.kickoff)) %>
                        </span>

                        <span>
                            <%= new Intl.DateTimeFormat('fa-IR', {
                                hour: '2-digit',
                                minute: '2-digit',
                                hour12: false,
                                timeZone: 'Asia/Tehran'
                            }).format(new Date(match.kickoff)) %>
                        </span>

                    </div>

                    <!-- TEAM 1 -->
                    <div class="team-row">
                        <span class="team-name"><%= match.team1 %></span>

                        <input type="number"
                               name="pred1"
                               min="0"
                               max="10"
                               class="team-input"
                               placeholder="-"
                               <%= isLocked ? "disabled" : "" %>
                               required>
                    </div>

                    <div class="vs">VS</div>

                    <!-- TEAM 2 -->
                    <div class="team-row">
                        <span class="team-name"><%= match.team2 %></span>

                        <input type="number"
                               name="pred2"
                               min="0"
                               max="10"
                               class="team-input"
                               placeholder="-"
                               <%= isLocked ? "disabled" : "" %>
                               required>
                    </div>

                    <!-- SIDE PREDICTION -->
                    <textarea name="side_prediction"
                              class="side-prediction"
                              placeholder="پیش بینی جانبی..."
                              <%= isLocked ? "disabled" : "" %>
                              maxlength="255"></textarea>

                    <button type="submit"
                            class="submit-btn <%= isLocked ? 'expired-submit' : '' %>"
                            <%= isLocked ? "disabled" : "" %>>
                        ثبت پیش بینی
                    </button>

                </form>

            <% }) %>

        </div>

    </div>

    <!-- =========================
        LEADERBOARD
    ========================= -->


    <div class="standings-section">

        <h2 class="standings-title">جدول امتیازات</h2>

        <div class="table-wrapper">

            <table class="standings-table">

                <!-- HEADER -->
                <thead>

                    <tr>

                        <!-- RANK -->
                        <th class="rank-header sticky-left-rank">
                            رتبه
                        </th>

                        <!-- PLAYER -->
                        <th class="player-header sticky-left-player">
                            بازیکن
                        </th>

                        <!-- MATCHES -->
                        <% matches.slice().reverse().forEach(match => { %>

                            <th>

                                <%= match.team1 %>
                                <br>

                                <% if (match.is_finished) { %>

                                    <%= match.result1 %> - <%= match.result2 %>

                                <% } else { %>

                                    VS

                                <% } %>

                                <br>

                                <%= match.team2 %>

                            </th>

                        <% }) %>

                        <!-- TOTAL POINTS -->
                        <th class="points-header sticky-right-points">
                            امتیاز
                        </th>

                    </tr>

                </thead>

                <!-- BODY -->
                <tbody>

                    <% users.forEach((user, index) => { %>

                        <tr class="<%= index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : '' %>">

                            <!-- RANK -->
                            <td class="rank sticky-left-rank">
                                <%= index + 1 %>
                            </td>

                            <!-- PLAYER -->
                            <td class="player-name sticky-left-player">

                                <div class="player-hover">

                                    <span class="player-link">
                                        <%= user.display_name %>
                                    </span>

                                    <div class="hover-card">

                                        <% if (user.ranking_prediction) { %>

                                            <p>🥇 <%= user.ranking_prediction.first_place %></p>
                                            <p>🥈 <%= user.ranking_prediction.second_place %></p>
                                            <p>🥉 <%= user.ranking_prediction.third_place %></p>
                                            <p>4️⃣ <%= user.ranking_prediction.fourth_place %></p>

                                        <% } %>

                                    </div>

                                </div>

                            </td>

                            <!-- MATCHES -->
                            <% matches.slice().reverse().forEach(match => { %>

                                <%

                                    const data =
                                        user.points?.[match.id];

                                    const started =
                                        new Date(match.kickoff) <= new Date();

                                %>

                                <td>

                                    <% if (!data) { %>

                                        -

                                    <% } else { %>

                                        <% if (started) { %>

                                            <div class="prediction-box">

                                                <div class="prediction">
                                                    <%= data.prediction ?? "-" %>
                                                </div>

                                                <div class="points">
                                                    <%= data.points ?? 0 %> pts
                                                </div>

                                                <% if (data.side_prediction) { %>

                                                    <div class="side">
                                                        📝 <%= data.side_prediction %>
                                                    </div>

                                                <% } %>

                                            </div>

                                        <% } else { %>

                                            🔒

                                        <% } %>

                                    <% } %>

                                </td>

                            <% }) %>

                            <!-- TOTAL POINTS -->
                            <td class="total-points sticky-right-points">
                                <%= user.total_points ?? 0 %>
                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

<script src="homepage.js"></script>

<!-- AUTO SCROLL TO NEXT MATCH -->
<script>
window.addEventListener("load", () => {

    const container = document.getElementById("matchesContainer");
    const matches = document.querySelectorAll(".match");

    const now = new Date();
    let targetMatch = null;

    // find next upcoming match
    matches.forEach(match => {
        const kickoff = new Date(match.dataset.kickoff);

        if (!targetMatch && kickoff > now) {
            targetMatch = match;
        }
    });

    // RTL-aware scroll positioning
    setTimeout(() => {

        if (targetMatch) {
            container.scrollLeft = targetMatch.offsetLeft;
        } else {
            // fallback: go to far right (latest matches side)
            container.scrollLeft = container.scrollWidth;
        }

    }, 50);

});
</script>


<% if (submitted) { %>
<script>
    alert("پیشبینی شما ثبت شد");
</script>
<% } %>

</body>
</html>