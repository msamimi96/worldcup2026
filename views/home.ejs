<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Cup 2026</title>

    <link rel="stylesheet" href="/css/homepage.css">
</head>

<body>
<div class="page">
        <div class="top-bar">

            <div class="user-name">
                خوش آمدی، <%= user.display_name %>
            </div>

            <form action="/logout" method="POST">
                <button type="submit">خروج</button>
            </form>

        </div>
<div class="upcoming-matches-container">

    <h2 class="title">بازی ها</h2>

    <div class="upcoming-matches" id="matchesContainer">

            <% matches.forEach(match => { %>

                    <% const isLocked = new Date(match.kickoff) < new Date(); %>

                    <form class="match" data-kickoff="<%= new Date(match.kickoff).toISOString() %>" action="/predict" method="POST">

                        <input type="hidden" name="match_id" value="<%= match.id %>">

                        <div class="date-time">

                            <span>
                                <%= new Intl.DateTimeFormat(
                                    'fa-IR-u-ca-persian',
                                    {
                                        year: 'numeric',
                                        month: '2-digit',
                                        day: '2-digit',
                                        timeZone: 'Asia/Tehran'
                                    }
                                ).format(new Date(match.kickoff)) %>
                            </span>

                            <span>
                                <%= new Intl.DateTimeFormat(
                                    'fa-IR',
                                    {
                                        hour: '2-digit',
                                        minute: '2-digit',
                                        hour12: false,
                                        timeZone: 'Asia/Tehran'
                                    }
                                ).format(new Date(match.kickoff)) %>
                            </span>

                        </div>

                        <div class="team-row">
                            <span class="team-name"><%= match.team1 %></span>

                            <input
                                type="number"
                                name="pred1"
                                min="0"
                                max="10"
                                class="team-input"
                                placeholder="-"
                                <%= isLocked ? "disabled" : "" %>
                                required
                            >
                        </div>

                        <div class="vs">VS</div>

                        <div class="team-row">
                            <span class="team-name"><%= match.team2 %></span>

                            <input
                                type="number"
                                name="pred2"
                                min="0"
                                max="10"
                                class="team-input"
                                placeholder="-"
                                <%= isLocked ? "disabled" : "" %>
                                required
                            >
                        </div>

                        <textarea
                            name="side_prediction"
                            placeholder="پیش بینی جانبی..."
                            maxlength="255"
                        ></textarea>

                        <button type="submit" class="submit-btn" <%= isLocked ? "disabled" : "" %>>
                            ثبت پیش بینی
                        </button>

                    </form>

                <% }) %>
    </div>

</div>

        <!-- Table -->

<!-- =========================
     STANDINGS SECTION
========================= -->

<div class="standings-section">

    <h2 class="standings-title">جدول امتیازات</h2>

    <div class="table-wrapper">

        <table class="standings-table">

            <!-- =========================
                 HEADER (MATCHES)
            ========================== -->
            <thead>
                <tr>

                    <!-- Left Sticky Column -->
                    <th class="sticky-left points-header">
                        امتیاز
                    </th>

                    <!-- Dynamic Match Columns -->
                    <% matches.forEach(match => { %>
                        <th>
                            <%= match.team1 %>
                            <br>

                            <% if (match.is_finished) { %>
                                <%= match.result1 %> - <%= match.result2 %>
                            <% } else { %>
                                VS
                            <% } %>

                            <br>
                            <%= match.team2 %>
                        </th>
                    <% }) %>

                    <!-- Right Sticky Column -->
                    <th class="sticky-right player-header">
                        بازیکن
                    </th>

                </tr>
            </thead>

            <!-- =========================
                 BODY (USERS)
            ========================== -->
                <tbody>

                    <% users.forEach((user, index) => { %>

                        <tr class="
                            <%= index === 0 ? 'gold' : '' %>
                            <%= index === 1 ? 'silver' : '' %>
                            <%= index === 2 ? 'bronze' : '' %>
                        ">

                            <!-- Rank (NEW) -->
                            <td class="rank">
                                <%= index + 1 %>
                            </td>

                            <!-- Total Points -->
                            <td class="sticky-left total-points">
                                <%= user.total_points ?? 0 %>
                            </td>

                            <!-- Match Points -->
                            <% matches.forEach(match => { %>

                                <td>
                                    <%= user.points?.[match.id] ?? "-" %>
                                </td>

                            <% }) %>

                            <!-- Username -->
                            <td class="sticky-right player-name">

                                <div class="player-hover">

                                    <span class="player-link">
                                        <%= user.display_name %>
                                    </span>

                                    <div class="hover-card">

                                        <% if (user.ranking_prediction) { %>

                                            <p>🥇 <%= user.ranking_prediction.first_place %></p>
                                            <p>🥈 <%= user.ranking_prediction.second_place %></p>
                                            <p>🥉 <%= user.ranking_prediction.third_place %></p>
                                            <p>4️⃣ <%= user.ranking_prediction.fourth_place %></p>

                                        <% } %>

                                    </div>

                                </div>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

        </table>

    </div>

</div>
</div>
<script src="homepage.js"></script>


<script>

window.addEventListener("load", () => {

    const container =
        document.getElementById("matchesContainer");

    const matches =
        document.querySelectorAll(".match");

    const now = new Date();

    let targetMatch = null;

    // find first upcoming match
    matches.forEach(match => {

        const kickoff =
            new Date(match.dataset.kickoff);

        if (!targetMatch && kickoff > now) {
            targetMatch = match;
        }

    });

    // scroll to it
    if (targetMatch) {

        container.scrollLeft =
            targetMatch.offsetLeft;

    }

});

</script>
</body>
</html>